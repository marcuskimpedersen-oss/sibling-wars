# Leave these unset for local dev (uses Vite proxy at localhost:2567)
# Set these when deploying the frontend to Vercel/Netlify etc.

# WebSocket URL of your deployed Colyseus server
# VITE_SERVER_WS_URL=wss://your-server.railway.app

# HTTP URL of your deployed Colyseus server (same host, different protocol)
# VITE_SERVER_HTTP_URL=https://your-server.railway.app
