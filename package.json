{
  "name": "rts-game",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "server:build": "tsc --project tsconfig.server.json",
    "server": "npm run server:build && node server/dist/index.js",
    "server:dev": "npm run server:build && node server/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@colyseus/core": "^0.16.5",
    "@colyseus/schema": "^3.0.76",
    "@colyseus/ws-transport": "^0.16.5",
    "colyseus": "^0.16.5",
    "colyseus.js": "^0.16.22",
    "cors": "^2.8.6",
    "easystarjs": "^0.4.4",
    "express": "^5.2.1",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
