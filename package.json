{
  "name": "rts-game",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "server": "node --require ts-node/register --loader ts-node/esm server/index.ts",
    "server:dev": "ts-node --project server/tsconfig.json server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@colyseus/ws-transport": "^0.17.11",
    "colyseus": "^0.17.8",
    "colyseus.js": "^0.16.22",
    "cors": "^2.8.6",
    "easystarjs": "^0.4.4",
    "express": "^5.2.1",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
